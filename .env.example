# ============================================
# HUTTLE AI — Environment Variables
# ============================================
# Copy to `.env` for local development. Never commit real `.env` files.

# ----- Supabase (client-side — safe to expose) -----
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ----- Stripe (client-side — publishable key only) -----
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_PRICE_ESSENTIALS_MONTHLY=price_xxx_essentials_monthly
VITE_STRIPE_PRICE_ESSENTIALS_ANNUAL=price_xxx_essentials_annual
VITE_STRIPE_PRICE_PRO_MONTHLY=price_xxx_pro_monthly
VITE_STRIPE_PRICE_PRO_ANNUAL=price_xxx_pro_annual
VITE_STRIPE_PRICE_FOUNDER_ANNUAL=price_xxx_founder_annual

# ----- App & API base (client) -----
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api

# ----- n8n Webhooks (client-side — webhook URLs, not secrets) -----
VITE_N8N_WEBHOOK_URL=your_n8n_webhook_base_url_here
VITE_N8N_CONNECTION_WEBHOOK_URL=your_n8n_connection_webhook_url_here
VITE_N8N_DASHBOARD_WEBHOOK=your_n8n_dashboard_webhook_url_here
VITE_N8N_PLAN_BUILDER_WEBHOOK=your_n8n_plan_builder_webhook_url_here
VITE_N8N_TREND_FORECASTER_WEBHOOK=your_n8n_trend_forecaster_webhook_url_here
VITE_N8N_IGNITE_ENGINE_WEBHOOK=https://your-n8n.app.n8n.cloud/webhook/...
VITE_N8N_SOCIAL_UPDATES_WEBHOOK=your_n8n_social_updates_webhook_url_here

# ============================================
# SERVER-SIDE ONLY — Vercel Environment Variables
# These are used by /api/* serverless functions ONLY.
# NEVER prefix these with VITE_ — they must not be in the client bundle.
# Set these in Vercel Dashboard → Project → Settings → Environment Variables.
# ============================================

# ----- AI API Keys (server-side only) -----
GROK_API_KEY=your_xai_grok_key
PERPLEXITY_API_KEY=your_perplexity_key
ANTHROPIC_API_KEY=your_anthropic_key

# ----- Stripe (server-side only) -----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- Supabase (server-side — URL + service role for admin operations) -----
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ----- Email (server-side) -----
RESEND_API_KEY=your_resend_api_key_here

# ----- n8n (server-side — used by Vercel serverless when applicable) -----
N8N_WEBHOOK_URL=your_n8n_webhook_url_here
N8N_CONNECTION_WEBHOOK_URL=your_n8n_connection_webhook_url_here
N8N_PLAN_BUILDER_WEBHOOK=your_n8n_plan_builder_webhook_url_here
N8N_IGNITE_ENGINE_WEBHOOK=your_n8n_ignite_engine_webhook_url_here

# ----- Cron (server-side only) -----
CRON_SECRET=your_cron_secret

# ============================================
# DEVELOPMENT ONLY — Do not set in production
# ============================================
# VITE_SKIP_AUTH=true  # Bypasses auth for local testing (DEV-gated, safe)
