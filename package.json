{
  "name": "huttle-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "concurrently --handle-input false -n api,vite -c blue,magenta \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "node server/local-api-server.js",
    "dev:frontend": "vite",
    "dev:vercel": "vercel dev",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "rm -rf node_modules/.vite .vite dist",
    "fresh": "npm run clean && npm run dev:local",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/20-smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:hooks-parser": "node scripts/verify-full-post-hooks-parser.mjs",
    "test:full-post-resilience": "node scripts/verify-full-post-resilience.mjs",
    "test:unit": "vitest run tests/unit",
    "dev:grok-smoke": "node scripts/dev-grok-fullpost-smoke.mjs",
    "dev:grok-models": "node scripts/dev-grok-models-verify.mjs",
    "qa:ai-tools": "node scripts/ai-tools-qa.mjs",
    "qa:reliability": "node scripts/reliability-qa.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/supabase-js": "^2.78.0",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.24.0",
    "lucide-react": "^0.548.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.2",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.3",
    "stripe": "^20.1.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "express": "^5.2.1",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.1.7",
    "vitest": "^4.1.2"
  }
}
